# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files

# --- Dependencies ---
/node_modules

# --- Build / compile output ---
/dist
/build
/tmp
/out-tsc
/bazel-out
*.tsbuildinfo

# --- Angular ---
/.angular/cache

# --- Environment & secrets ---
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
secrets.json

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Test & coverage ---
/coverage
.nyc_output
__screenshots__/
testem.log
/libpeerconnection.log

# --- Caches ---
.sass-cache/
.cache/
.parcel-cache/
.eslintcache
.turbo
/connect.lock
/typings

# --- IDEs & editors ---
.idea/
*.iml
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project

# Visual Studio Code (keep shared workspace config)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Misc ---
*.swp
*.swo
*~
*.orig
*.local
